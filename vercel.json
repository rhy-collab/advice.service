{
    "services": {
        "frontend": {
            "root": "frontend",
            "framework": "vite"
        },
        "backend": {
            "root": "backend",
            "framework": "fastapi",
            "entrypoint": "app/main.py"
        }
    },
    "rewrites": [
        {
            "source": "/",
            "destination": "/landing.html"
        },
        {
            "source": "/api(/.*)?",
            "destination": {
                "type": "service",
                "service": "backend"
            }
        },
        {
            "source": "/((?!api/|assets/|.*\\.[a-z0-9]+$).*)",
            "destination": "/index.html"
        },
        {
            "source": "/(.*)",
            "destination": {
                "type": "service",
                "service": "frontend"
            }
        }
    ]
}
